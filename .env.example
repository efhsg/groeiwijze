# Groeiwijze Docker - Environment Variables
# Copy this file to .env and fill in your values

# SMTP Settings
SMTP_HOST=mail.groeiwijze.nl
SMTP_PORT=587
SMTP_USER=your-smtp-user@groeiwijze.nl
SMTP_PASS=your-smtp-password

# Mail Settings
MAIL_FROM=your-smtp-user@groeiwijze.nl
MAIL_FROM_NAME=Groeiwijze
MAIL_TO=anja@groeiwijze.nl

# Security
RATE_LIMIT_SALT=groeiwijze_ratelimit_2024

# === Publish (mijn.host SFTP) ===
# Vul in via DirectAdmin (https://h53.mijn.host:2222) onder "FTP Beheer" /
# "SSH-toegang", of via de welkomstmail van mijn.host.
# .env staat in .gitignore — credentials komen niet in git terecht.

# SFTP host. Vaak h53.mijn.host of je eigen domein. NIET de :2222 panel-URL.
PUBLISH_HOST=

# SFTP poort. mijn.host gebruikt 26 (niet de SSH-default 22). 2222 is de
# DirectAdmin webpanel-poort, niet SFTP.
PUBLISH_PORT=26

# SFTP gebruikersnaam (meestal gelijk aan je DirectAdmin login).
PUBLISH_USER=

# SFTP wachtwoord. NIET gebruikt door scripts/publish.sh — dat script doet
# alleen key-auth. Hier voor jouw eigen ad-hoc lftp/sftp/FileZilla-sessies.
PUBLISH_PASS=

# Pad naar een private SSH-key. Verplicht voor scripts/publish.sh.
# Relatief aan project-root, of absoluut. Standaard pad voor het
# AI-runner publish-contract: .publish/keys/<target>/id_ed25519
PUBLISH_KEY=.publish/keys/production/id_ed25519

# Pad op de host vanaf je SSH-home, naar de site-root waar public_html/,
# vendor/ en private/ onder hangen. Bij mijn.host doorgaans: domains/groeiwijze.nl
PUBLISH_REMOTE_BASE=domains/groeiwijze.nl

# Naam van de document root binnen PUBLISH_REMOTE_BASE.
# Bij mijn.host doorgaans: public_html
PUBLISH_REMOTE_DOCROOT=public_html

# Publish (AI-runner publish-contract)
# Optioneel: PromptManager-user die als initiator in de auditlog komt.
# Default 1 als de var niet gezet is. AI_RUNNER_ROLE wordt door de
# runner-container zelf gezet (web/worker/quick) en hoort hier NIET in.
PUBLISH_OWNER_ID=1
