# Groeiwijze Docker - Environment Variables
# Copy this file to .env and fill in your values

# SMTP Settings
SMTP_HOST=mail.groeiwijze.nl
SMTP_PORT=587
SMTP_USER=your-smtp-user@groeiwijze.nl
SMTP_PASS=your-smtp-password

# Mail Settings
MAIL_FROM=your-smtp-user@groeiwijze.nl
MAIL_FROM_NAME=Groeiwijze
MAIL_TO=anja@groeiwijze.nl

# Security
RATE_LIMIT_SALT=groeiwijze_ratelimit_2024
