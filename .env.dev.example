# Groeiwijze - Development overrides template
#
# Copy to .env.dev. Wordt door docker-compose bovenop .env geladen.
# Alleen velden die in dev anders moeten dan in productie.
# Niet gelezen door scripts/publish.sh.

# Verplichte marker — generate-config.sh weigert te starten als deze ontbreekt.
APP_ENV=dev

# === Mail (override naar mailcatcher / Mailpit-sidecar) ===
# Alle uitgaande mail wordt opgevangen door de mailcatcher-sidecar uit
# docker-compose.yml. Bereikt nooit echte mailboxen.
SMTP_HOST=mailcatcher
SMTP_PORT=1025
SMTP_USER=mailpit
SMTP_PASS=mailpit
SMTP_SECURE=
SMTP_SKIP_VERIFY=false

# Mail Settings (dev — fictieve adressen)
MAIL_FROM=dev-noreply@groeiwijze.local
MAIL_FROM_NAME="Groeiwijze (dev)"
MAIL_TO=dev-anja@groeiwijze.local
